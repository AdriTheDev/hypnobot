generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model UserLevel {
  id            String    @id @default(cuid())
  userId        String
  guildId       String
  xp            BigInt    @default(0)
  level         BigInt    @default(0)
  messages      Int       @default(0)
  lastMessageAt DateTime?
  leftGuildAt   DateTime?

  @@unique([userId, guildId])
  @@index([guildId, xp(sort: Desc)])
}

model Warning {
  id          String    @id @default(cuid())
  userId      String
  guildId     String
  reason      String
  moderatorId String
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  @@index([userId, guildId])
}

model TempBan {
  id          String   @id @default(cuid())
  userId      String
  guildId     String
  reason      String
  moderatorId String
  expiresAt   DateTime

  @@unique([userId, guildId])
  @@index([expiresAt])
}

model GuildAlias {
  id      String @id @default(cuid())
  guildId String
  name    String
  value   String
  type    String

  @@unique([guildId, type, name])
}

model WelcomeMessage {
  userId    String
  guildId   String
  channelId String
  messageId String

  @@id([userId, guildId])
}

model GuildConfig {
  guildId           String   @id
  noXpRoles         String[]
  noXpChannels      String[]
  modLogChannel     String?
  welcomeChannel    String?
  goodbyeChannel    String?
  introChannel      String?
  forumChannels     String[] @default([])
  messageLogChannel String?
  memberLogChannel  String?
  serverLogChannel  String?
  voiceLogChannel      String?
  publicModLogChannel  String?
  leaderboardChannel   String?
  leaderboardMessageId String?
  joinRoles            String[] @default([])
  welcomeMessage          String?
  goodbyeMessage          String?
  xpEnabled               Boolean  @default(true)
  restoreRoles            Boolean  @default(false)
  lockdownExemptChannels  String[] @default([])
  aiReportChannel         String?
  joinToCreateChannel     String?
}

model UserNote {
  id          String   @id @default(cuid())
  userId      String
  guildId     String
  content     String
  authorId    String
  createdAt   DateTime @default(now())

  @@index([userId, guildId])
}

model RoleSnapshot {
  userId  String
  guildId String
  roleIds String[]
  savedAt DateTime @default(now())

  @@id([userId, guildId])
}

model SuspendedUser {
  userId      String
  guildId     String
  roleIds     String[]
  moderatorId String
  reason      String
  suspendedAt DateTime  @default(now())
  expiresAt   DateTime?

  @@id([userId, guildId])
}

model MinecraftWhitelist {
  userId            String
  guildId           String
  minecraftUsername String
  minecraftUuid     String
  addedAt           DateTime @default(now())

  @@id([userId, guildId])
  @@unique([guildId, minecraftUsername])
  @@index([guildId])
}

model AccountLink {
  id      String @id @default(cuid())
  guildId String
  userId  String
  altId   String

  @@unique([guildId, userId, altId])
  @@index([guildId, userId])
  @@index([guildId, altId])
}

model AutomodFactor {
  id      String @id @default(cuid())
  guildId String
  type    String
  value   String
  points  Int

  @@unique([guildId, type, value])
  @@index([guildId])
}

model JoinToCreateVC {
  channelId     String   @id
  guildId       String
  ownerId       String
  managerId     String
  memberIds     String[]
  bannedUserIds String[] @default([])
  isGhosted     Boolean  @default(false)

  @@index([guildId])
}

model AiReport {
  id           String    @id @default(cuid())
  guildId      String
  channelId    String
  messageId    String
  messageUrl   String
  authorId     String
  logMessageId String?
  reporterIds  String[]
  aiVoters     String[]
  notAiVoters  String[]
  status       String    @default("pending")
  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?
  resolvedById String?

  @@unique([guildId, messageId])
  @@index([guildId, status])
}

model MeowCount {
  id      String @id @default(cuid())
  guildId String
  userId  String
  word    String
  count   Int    @default(0)

  @@unique([guildId, userId, word])
  @@index([guildId, word])
  @@index([guildId, userId])
}
