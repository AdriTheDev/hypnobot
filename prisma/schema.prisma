generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model UserLevel {
  id            String    @id @default(cuid())
  userId        String
  guildId       String
  xp            BigInt    @default(0)
  level         BigInt    @default(0)
  messages      Int       @default(0)
  lastMessageAt DateTime?

  @@unique([userId, guildId])
  @@index([guildId, xp(sort: Desc)])
}

model Warning {
  id          String    @id @default(cuid())
  userId      String
  guildId     String
  reason      String
  moderatorId String
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  @@index([userId, guildId])
}

model TempBan {
  id          String   @id @default(cuid())
  userId      String
  guildId     String
  reason      String
  moderatorId String
  expiresAt   DateTime

  @@unique([userId, guildId])
  @@index([expiresAt])
}

model GuildAlias {
  id      String @id @default(cuid())
  guildId String
  name    String
  value   String
  type    String

  @@unique([guildId, type, name])
}

model WelcomeMessage {
  userId    String
  guildId   String
  channelId String
  messageId String

  @@id([userId, guildId])
}

model GuildConfig {
  guildId           String   @id
  noXpRoles         String[]
  noXpChannels      String[]
  modLogChannel     String?
  welcomeChannel    String?
  goodbyeChannel    String?
  introChannel      String?
  forumChannels     String[] @default([])
  messageLogChannel String?
  memberLogChannel  String?
  serverLogChannel  String?
  voiceLogChannel      String?
  publicModLogChannel  String?
  leaderboardChannel   String?
  leaderboardMessageId String?
  joinRoles            String[] @default([])
  xpEnabled            Boolean  @default(true)
  restoreRoles         Boolean  @default(false)
}

model UserNote {
  id          String   @id @default(cuid())
  userId      String
  guildId     String
  content     String
  authorId    String
  createdAt   DateTime @default(now())

  @@index([userId, guildId])
}

model RoleSnapshot {
  userId  String
  guildId String
  roleIds String[]
  savedAt DateTime @default(now())

  @@id([userId, guildId])
}
