# Discord
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here
OWNER_IDS=comma,separated,owner,ids

# Set to "true" to register commands only to the dev guild instead of globally
DEV_MODE=false
DEV_GUILD_ID=your_dev_guild_id_here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/hypnobot

# Status webhook (optional) — receives startup/shutdown/restart notifications
STATUS_WEBHOOK_URL=https://discord.com/api/webhooks/...
