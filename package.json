{
	"name": "hypnobot",
	"version": "1.0.0",
	"description": "A Discord bot with advanced command/event handling and leveling.",
	"main": "dist/index.js",
	"scripts": {
		"build": "tsc",
		"start": "node dist/index.js",
		"dev": "ts-node-dev --respawn --transpile-only src/index.ts",
		"db:generate": "prisma generate",
		"db:push": "prisma db push",
		"db:migrate": "prisma migrate dev",
		"prettier": "prettier --write \"./**/*.{js,jsx,mjs,cjs,ts,tsx,json,yml}\""
	},
	"dependencies": {
		"@napi-rs/canvas": "^0.1.53",
		"@prisma/client": "^5.22.0",
		"discord.js": "^14.16.3",
		"dotenv": "^16.4.5",
		"ms": "^2.1.3"
	},
	"devDependencies": {
		"@types/ms": "^2.1.0",
		"@types/node": "^22.9.0",
		"prettier": "^3.8.3",
		"prisma": "^5.22.0",
		"ts-node-dev": "^2.0.0",
		"typescript": "^5.6.3"
	},
	"allowScripts": {
		"@prisma/client@5.22.0": true,
		"@prisma/engines@5.22.0": true,
		"prisma@5.22.0": true
	}
}
