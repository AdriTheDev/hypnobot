{
	"name": "hypnobot",
	"version": "1.5.3",
	"description": "A Discord bot with advanced command/event handling and leveling.",
	"main": "dist/index.js",
	"type": "module",
	"scripts": {
		"build": "tsc --noEmit",
		"start": "tsx --env-file=.env src/index.ts",
		"dev": "tsx watch --env-file=.env src/index.ts",
		"deploy": "tsx --env-file=.env src/deploy.ts",
		"db:generate": "prisma generate",
		"db:push": "prisma db push",
		"db:migrate": "prisma migrate dev",
		"db:backfill-left": "tsx --env-file=.env scripts/backfill-left-members.ts",
		"prettier": "prettier --write \"./**/*.{js,jsx,mjs,cjs,ts,tsx,json,yml}\""
	},
	"dependencies": {
		"@fontsource/montserrat": "^5.2.8",
		"@napi-rs/canvas": "^1.0.0",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"discord.js": "^14.16.3",
		"dotenv": "^17.4.2",
		"ms": "^2.1.3",
		"pg": "^8.21.0",
		"rcon-client": "^4.2.5",
		"tsx": "^4.22.4"
	},
	"devDependencies": {
		"@types/ms": "^2.1.0",
		"@types/node": "^25.9.1",
		"@types/pg": "^8.20.0",
		"prettier": "^3.8.3",
		"prisma": "^7.8.0",
		"typescript": "^6.0.3"
	},
	"allowScripts": {
		"@prisma/engines@7.8.0": true,
		"esbuild@0.28.0": true,
		"prisma@7.8.0": true
	}
}
